{
    "name": "please-test",
    "version": "1.0.0",
    "description": "Shorthand helper for @playwright/test — expressive locators, readable error messages",
    "main": "master/index.js",
    "scripts": {
        "test:unit": "node test/unit.test.js && node test/screenshot.test.js",
        "test:login": "npx playwright test test/login.spec.js",
        "test": "npx playwright test test/smoke.test.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ghany-ersa/please-test.git"
    },
    "keywords": [
        "playwright",
        "automation",
        "testing",
        "e2e",
        "shorthand"
    ],
    "author": "ghany-ersa <ghanyersa24@gmail.com>",
    "license": "MIT",
    "peerDependencies": {
        "@playwright/test": ">=1.0.0"
    },
    "engines": {
        "node": ">=14.0.0"
    },
    "files": [
        "master/"
    ],
    "devDependencies": {
        "@playwright/test": "^1.61.0"
    }
}
